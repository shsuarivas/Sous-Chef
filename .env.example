#=================================================================================================================
# .env file for ByteYourForkDB
# Copy this file to .env and fill in the values
# You should not commit your .env file to the repo as it may contain sensitive information.
# Fill in the values below with your own configurations and save the file as .env in the root of your project.
# Values look like this: KEY=value
#==================================================================================================================

# PostgreSQL database 
POSTGRES_USER=SousChef
POSTGRES_PASSWORD=password
POSTGRES_DB=appdb

# Backend settings
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://SousChef:password@postgres:5432/appdb
JWT_SECRET=your_jwt_secret_here

# Frontend settings
VITE_API_URL=http://localhost:8080
# Email (Resend)
RESEND_API_KEY=keyhere
EMAIL_FROM=noreply@byteyourfork.com

GEMINI_API_KEY=keyhere